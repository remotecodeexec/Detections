<rules>
    <DataRequest functionCategory="Security" mode="Streaming">
        <Name>Multiple Logon Failures: Database / SCW</Name>
        <Description>Detects excessive database logon failures - 25 consecutive failures in a 10 minute period</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,reptDevIpAddr,srcIpAddr,srcName,user,destIpPort,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>$incidentCount logon failures $msg</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="600">
            <SubPattern id="3483392465" name="ExcessDBLoginFailure1">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_DBLogonFailure)</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=25</GroupEvtConstr>
                <GroupByAttr>reptDevIpAddr,reptDevName,msg</GroupByAttr>
            </SubPattern>
            <Operator rank="0" type="OR"/>
            <SubPattern id="3483392466" name="ExcessDBLoginFailure2">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_DBLogonFailure)</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=25</GroupEvtConstr>
                <GroupByAttr>reptDevIpAddr,reptDevName,msg</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Multiple_Logon_Failures_Database_SIBS_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="6">
            <ArgList>destName = ExcessDBLoginFailure1.reptDevName,destName = ExcessDBLoginFailure2.reptDevName,destIpAddr = ExcessDBLoginFailure1.reptDevIpAddr,destIpAddr = ExcessDBLoginFailure2.reptDevIpAddr,incidentCount = ExcessDBLoginFailure1.COUNT(*),incidentCount = ExcessDBLoginFailure2.COUNT(*),msg = ExcessDBLoginFailure1.msg,msg = ExcessDBLoginFailure2.msg</ArgList>
        </IncidentDef>
        <DynWatchLists>
            <DynWatchListDef attr="destIpAddr">
                <WatchList>PH_DYNLIST_SERVER_FAILED_LOGIN</WatchList>
            </DynWatchListDef>
        </DynWatchLists>
    </DataRequest>
</rules>

