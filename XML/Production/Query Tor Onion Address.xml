<rules>
    <DataRequest functionCategory="Other" mode="Streaming" tactic="Command And Control" technique="T1090.003" techniqueName="Proxy: Multi-hop Proxy">
        <Name>Query Tor Onion Address / SCW</Name>
        <Description>Detects DNS resolution of an .onion address related to Tor routing networks</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,reptDevIpAddr,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="3802383653" name="onion">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_CommonDNSTraffic,Group@PH_SYS_EVENT_PermitWebTraffic) AND dnsQueryName CONTAIN ".onion"</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>destName,srcIpAddr</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Query_Tor_Onion_Address_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE" fireFreq="3600" severity="7">
            <ArgList>srcIpAddr = onion.srcIpAddr,destName = onion.destName</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

