<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Command And Control" technique="T1568.001" techniqueName="Dynamic Resolution: Fast Flux DNS">
        <Name>Excessive Denied DNS Queries / SCW</Name>
        <Description>Detects a scenario where a host, has a very high frequency of denied DNS traffic.</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,srcIpAddr,destIpAddr,ipProto,srcIpPort,destIpPort,reptDevIpAddr,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Excessive Denied DNS Queries from $srcIpAddr</IncidentTitle>
        <Remediation/>
        <DataSource>FortiGate via Syslog or Netflow, Checkpoint via Syslog or Netflow, Palo Alto via Syslog or Netflow</DataSource>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="5696063806" name="DeniedDNS">
                <SingleEvtConstr>ipProto=6 AND destIpPort=53 AND eventType IN (Group@PH_SYS_EVENT_DenyNetTraffic) AND srcIpAddr IN (Group@PH_SYS_NETWORK_ENTERPRISE_INTERNAL_NET)</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=100</GroupEvtConstr>
                <GroupByAttr>srcIpAddr</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <Tag>SCW,Traffic Anomaly</Tag>
        <IncidentDef eventType="Excessive_Denied_DNS_Queries_SCW" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="6">
            <ArgList>srcIpAddr = DeniedDNS.srcIpAddr,incidentCount = DeniedDNS.COUNT(*)</ArgList>
        </IncidentDef>
        <DynWatchLists>
            <DynWatchListDef attr="srcIpAddr">
                <WatchList>PH_DYNLIST_DNS_VIOLATOR</WatchList>
            </DynWatchListDef>
        </DynWatchLists>
    </DataRequest>
</rules>

