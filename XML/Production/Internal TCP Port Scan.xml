<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Discovery" technique="T1046" techniqueName="Network Service Scanning">
        <Name>Internal TCP Port Scan / SCW</Name>
        <Description>Detects pattern of tcp port scan</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,reptDevIpAddr,eventType,srcIpAddr,srcIpPort,destIpAddr,destIpPort,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Internal Heavy TCP Port Scan from $srcIpAddr to $destIpAddr to different 1024 ports</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="3751865402" name="Internal_TCP_Port_Scan_SCW">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_PermitNetTraffic,Group@PH_SYS_EVENT_DenyNetTraffic) AND (srcIpAddr IN (Group@PH_SYS_NETWORK_ENTERPRISE_INTERNAL_NET) AND destIpAddr IN (Group@PH_SYS_NETWORK_ENTERPRISE_INTERNAL_NET) AND srcIpAddr!=destIpAddr) AND ipProto=6</SingleEvtConstr>
                <GroupEvtConstr>COUNT(DISTINCT destIpPort)&gt;=25</GroupEvtConstr>
                <GroupByAttr>destIpAddr,srcIpAddr,srcIpPort,destIpPort</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <Tag>SCW</Tag>
        <IncidentDef eventType="Internal_TCP_Port_Scan_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="900" severity="7">
            <ArgList>srcIpAddr = Internal_TCP_Port_Scan_SCW.srcIpAddr,destIpAddr = Internal_TCP_Port_Scan_SCW.destIpAddr,srcIpPort = Internal_TCP_Port_Scan_SCW.srcIpPort,destIpPort = Internal_TCP_Port_Scan_SCW.destIpPort</ArgList>
        </IncidentDef>
        <DynWatchLists>
            <DynWatchListDef attr="srcIpAddr">
                <WatchList>PH_DYNLIST_PORT_SCANNER</WatchList>
            </DynWatchListDef>
        </DynWatchLists>
    </DataRequest>
</rules>

