<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Discovery" technique="T1046" techniqueName="Network Service Scanning">
        <Name>Multiple IPS Detected Scans From Same Src / SCW</Name>
        <Description>Detects multiple IPS detected scans from the same source IP in a short period of time.</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,srcIpAddr,destIpAddr,ipProto,srcIpPort,destIpPort,reptDevIpAddr,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Multiple IPS detected scans from $srcIpAddr</IncidentTitle>
        <Remediation/>
        <DataSource>FortiGate via Syslog, FortiProxy via Syslog, Checkpoint IPS-1 via LEA/Syslog, PaloAlto PAN-OS via Syslog</DataSource>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="4683157225" name="IPSScan">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_Reconn)</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=2</GroupEvtConstr>
                <GroupByAttr>ipsSignatureId,fwAction,srcIpAddr</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <Tag>SCW</Tag>
        <IncidentDef eventType="Multiple_IPS_Detected_Scans_From_Same_Src_SIBSCyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="7">
            <ArgList>srcIpAddr = IPSScan.srcIpAddr,ipsSignatureId = IPSScan.ipsSignatureId,fwAction = IPSScan.fwAction</ArgList>
        </IncidentDef>
        <DynWatchLists>
            <DynWatchListDef attr="srcIpAddr">
                <WatchList>PH_DYNLIST_HOST_SCANNER</WatchList>
            </DynWatchListDef>
        </DynWatchLists>
    </DataRequest>
</rules>

