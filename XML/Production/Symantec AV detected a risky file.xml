<?xml version="1.0" encoding="UTF-8"?><rules><DataRequest functionCategory="Security" mode="Streaming" tactic="Execution" technique="T1204.002" techniqueName="User Execution: Malicious File"><Name>Symantec AV detected a risky file / SCW</Name><Description>This rule gets all events from symantec identified with a risk level</Description><Remediation/><DataSource>Symantec via SYSLOG</DataSource><DetectionTechnology>Correlation</DetectionTechnology><PatternClause window="300">
<SubPattern id="1654087599" name="Risky_file">
<SingleEvtConstr>eventType="Symantec-AV-Generic" AND riskName IS NOT NULL</SingleEvtConstr>
<GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
<GroupByAttr>appName,computer,fwAction,riskName</GroupByAttr>
</SubPattern>
<Operator rank="0" type="OR"/>
<SubPattern id="1654087600" name="Virus_found">
<SingleEvtConstr>(eventType="Symantec-AV-Virus-Found" OR eventType="Symantec-AV-Trojan-Worm") AND appName!="way4manager.exe"</SingleEvtConstr>
<GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
<GroupByAttr>computer,appName,riskName,fwAction</GroupByAttr>
</SubPattern>
</PatternClause><IncidentDef eventType="Symantec_AV_detected_a_risky_file_SCW" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="900" severity="8">
<ArgList>appName = Risky_file.appName,computer = Risky_file.computer,fwAction = Risky_file.fwAction,riskName = Risky_file.riskName</ArgList>
</IncidentDef><DynWatchLists/><TriggerEventDisplay>
<AttrList>phRecvTime,eventType,reptDevIpAddr,rawEventMsg</AttrList>
</TriggerEventDisplay><IncidentTitle>A potencially risky file has been found on $computer </IncidentTitle></DataRequest></rules>
