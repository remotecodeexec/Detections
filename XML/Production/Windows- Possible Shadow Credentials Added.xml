<rules>
    <DataRequest functionCategory="Security" mode="Streaming">
        <Name>Windows: Possible Shadow Credentials Added / SCW</Name>
        <Description>Detects possible addition of shadow credentials to an active directory object. This rule is adapted from https://github.com/SigmaHQ/sigma/blob/master/rules/windows/builtin/security/win_security_susp_possible_shadow_credentials_added.yml</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,hostName,propName,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Possible Shadow Credentials Added on $hostName</IncidentTitle>
        <Remediation/>
        <DataSource>Windows Security Log via OMI or FortiSIEM Agent</DataSource>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="4623293103" name="Filter">
                <SingleEvtConstr>eventType="Win-Security-5136" AND propName="msDS-KeyCredentialLink"</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>propName,user,hostName</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Windows_Possible_Shadow_Credentials_Added_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="7">
            <ArgList>hostName = Filter.hostName,propName = Filter.propName,user = Filter.user</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

