<rules>
    <DataRequest functionCategory="Availability" mode="Streaming">
        <Name>Excessive Clock Skew Between Collector and Supervisor nodes / SCW</Name>
        <Description>Detects that more than 2 min clock skew  between collector and super - this will cause real time rules to not trigger for events received from that collector</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,phCustId,customer,collectorIp,collectorTime,superTime,timeSkewSec,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Excessive Clock Skew Between Collector $collectorIp customer $customer and Supervisor node</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="600">
            <SubPattern id="4291472154" name="clockSkew">
                <SingleEvtConstr>phEventCategory=3 AND eventType="PH_COLLECTOR_CLOCK_SKEW"</SingleEvtConstr>
                <GroupEvtConstr>AVG(timeSkewSec)&gt;=200 AND COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>collectorIp,customer,phCustId</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Excessive_Clock_Skew_Between_Collector_and_Supervisor_nodes_15_09_2023" eventTypeGroup="PH_SYS_EVENT_PH_RULE_AVAIL" fireFreq="86400" severity="9">
            <ArgList>phCustId = clockSkew.phCustId,customer = clockSkew.customer,collectorIp = clockSkew.collectorIp,timeSkewSec = clockSkew.AVG(timeSkewSec)</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

