<rules>
    <DataRequest functionCategory="Security" mode="Streaming">
        <Name>Windows: Programs starting from Suspicious Location / SCW</Name>
        <Description>Detects programs running in suspicious files system locations. This rule is adapted from https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/win_susp_prog_location_process_starts.yml</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,hostName,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Programs starting from Suspicious Location on $hostName</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="4117849601" name="Filter">
                <SingleEvtConstr>eventType="Win-Sysmon-1-Create-Process" AND procName REGEXP ".*\\\\Users\\\\Public\\\\.*|.*\\\\Windows\\\\Fonts\\\\.*|.*\\\\Windows\\\\IME\\\\.*|.*\\\\Windows\\\\addins\\\\.*|.*\\\\Windows\\\\debug\\\\.*|.*\\\\\\$Recycle\\.bin|C:\\\\Perflogs\\\\.*"</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>procName,hostName</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Windows_Programs_starting_from_Suspicious_Location_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="7">
            <ArgList>hostName = Filter.hostName,procName = Filter.procName</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

