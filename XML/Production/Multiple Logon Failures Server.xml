<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Credential Access" technique="T1110.001" techniqueName="Brute Force: Password Guessing">
        <Name>Multiple Logon Failures: Server / SCW</Name>
        <Description>Detects excessive logon failures at a server - 5 consecutive failures in a 10 minute period</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,reptDevIpAddr,srcIpAddr,user,destIpPort,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>$incidentCount login failures for user $user from $srcIpAddr on server $destName</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="600">
            <SubPattern id="3920932153" name="ExcessServerLoginFailure">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_HostLogonFailure) AND reptDevIpAddr IN (Group@PH_SYS_DEVICE_Server) AND reptDevIpAddr NOT IN (Group@PH_SYS_APP_DOMAIN_CONTROLLER) AND user NOT CONTAIN "$"</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=10</GroupEvtConstr>
                <GroupByAttr>user,reptDevIpAddr,reptDevName,srcIpAddr</GroupByAttr>
            </SubPattern>
            <Operator rank="0" type="OR"/>
            <SubPattern id="3920932154" name="ExcessServerLoginFailure2">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_MultipleHostLogonFailure) AND reptDevIpAddr IN (Group@PH_SYS_DEVICE_Server) AND reptDevIpAddr NOT IN (Group@PH_SYS_APP_DOMAIN_CONTROLLER) AND user NOT CONTAIN "$"</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>srcIpAddr,reptDevName,reptDevIpAddr,user</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Multiple_Logon_Failures_Server_CyberWatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="6">
            <ArgList>srcIpAddr = ExcessServerLoginFailure.srcIpAddr,srcIpAddr = ExcessServerLoginFailure2.srcIpAddr,destName = ExcessServerLoginFailure.reptDevName,destName = ExcessServerLoginFailure2.reptDevName,destIpAddr = ExcessServerLoginFailure.reptDevIpAddr,destIpAddr = ExcessServerLoginFailure2.reptDevIpAddr,user = ExcessServerLoginFailure.user,user = ExcessServerLoginFailure2.user,incidentCount = ExcessServerLoginFailure.COUNT(*),incidentCount = ExcessServerLoginFailure2.COUNT(*)</ArgList>
        </IncidentDef>
        <DynWatchLists>
            <DynWatchListDef attr="destIpAddr">
                <WatchList>PH_DYNLIST_SERVER_FAILED_LOGIN</WatchList>
            </DynWatchListDef>
        </DynWatchLists>
    </DataRequest>
</rules>

