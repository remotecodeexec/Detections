<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Exfiltration" technique="T1041" techniqueName="Exfiltration Over C2 Channel">
        <Name>Outbreak: DARKSIDE Ransomware Inbound Network Traffic Detected / SCW</Name>
        <Description>Detects if Inbound traffic to known malicious IPs associated with DarkSide occurred.</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,reptDevIpAddr,reptDevName,srcIpAddr,destIpAddr,destIpPort,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>DARKSIDE Ransomware Inbound Network Traffic seen from $srcIpAddr to $destIpAddr</IncidentTitle>
        <Remediation>Check if the source is patched for the CVE associated with the event. If yes then remove the host from the network and patch immediately. If host is not scanned then determine if the host is running the affected version of the application. If yes then patch immediately, else it is likely a false positive.</Remediation>
        <DataSource>FortiGate via Syslog or Netflow, Cisco IOS via Syslog or Netflow, Checkpoint via Syslog or Netflow, Palo Alto via Syslog or Netflow</DataSource>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="5309936201" name="darkside">
                <SingleEvtConstr>srcIpAddr IN (176.123.2.216,51.210.138.71,185.105.109.19,192.3.141.157,213.252.247.18,23.95.85.176,159.65.225.72,80.209.241.4,46.166.128.144,108.62.118.232,185.203.116.7,185.203.117.159,104.21.69.79,172.67.206.76,185.203.116.28,198.54.117.197,198.54.117.199,185.243.214.107,45.61.138.171,45.84.0.127,88.85.66.195,139.45.195.28,139.45.195.93,139.45.196.12,139.45.196.74,146.185.16.146,173.192.200.70,173.237.15.140,173.237.15.156,185.225.208.133,193.124.201.171,88.85.66.196,88.85.66.201,88.85.82.153,88.85.82.189,89.19.36.48,139.45.195.149) AND eventType IN (Group@PH_SYS_EVENT_PermitNetTraffic,Group@PH_SYS_EVENT_NetflowTraffic,Group@PH_SYS_EVENT_BiNetflowTraffic,Group@PH_SYS_EVENT_DenyNetTraffic) AND fwAction NOT IN ("deny","Denied")</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>srcIpAddr,destIpAddr</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Outbreak_DARKSIDE_Ransomware_Inbound_Network_Traffic_Detected_Clone" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="9">
            <ArgList>srcIpAddr = darkside.srcIpAddr,destIpAddr = darkside.destIpAddr</ArgList>
        </IncidentDef>
        <DynWatchLists>
            <DynWatchListDef attr="destIpAddr">
                <WatchList>PH_DYNLIST_LIKELY_MALWARE</WatchList>
            </DynWatchListDef>
        </DynWatchLists>
    </DataRequest>
</rules>

