<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Persistence,Privilege Escalation,Defense Evasion,Initial Access" technique="T1078.003" techniqueName="Valid Accounts: Local Accounts">
        <Name>Sudden Increase in Failed Logons To A Host / SCW</Name>
        <Description>Detects a sudden 50% increase of failed logons to a specific host over a 30 minute window</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,reptDevName,reptDevIpAddr,user,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Sudden Increase in Failed Logons to $hostName from $avgMatchedEvents to $count</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="1800">
            <SubPattern id="3691890983" name="Logon">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_HostLogonFailure) AND user NOT CONTAIN "$" AND user!="aralab" AND user!="nGUser"</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=30 AND COUNT(*)&gt;=1.50*STAT_AVG(COUNT(*):122)</GroupEvtConstr>
                <GroupByAttr>reptDevIpAddr,user,reptDevName</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <IncidentDef eventType="Sudden_Increase_in_Failed_Logons_To_A_Host_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="7">
            <ArgList>hostName = Logon.reptDevName,hostIpAddr = Logon.reptDevIpAddr,count = Logon.COUNT(*),avgMatchedEvents = Logon.STAT_AVG(COUNT(*):122)</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

