<rules>
    <DataRequest functionCategory="Security" mode="Streaming">
        <Name>Sudden Increase in Successful Logons To A Host / SCW</Name>
        <Description>Detects a sudden 50% increase of successful logons to a host over a 30 minute window</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,reptDevName,reptDevIpAddr,user,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Sudden Increase in Successful Logons to $hostName from $avgMatchedEvents to $count</IncidentTitle>
        <Remediation/>
        <DataSource/>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="1800">
            <SubPattern id="3310860857" name="Logon">
                <SingleEvtConstr>eventType IN (Group@PH_SYS_EVENT_HostLogonSuccess)</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=35 AND COUNT(*)&gt;=1.50*STAT_AVG(COUNT(*):115)</GroupEvtConstr>
                <GroupByAttr>reptDevIpAddr,reptDevName</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <Tag>Incident Report</Tag>
        <IncidentDef eventType="Sudden_Increase_in_Successful_Logons_To_A_Host_Cyberwatch" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="7">
            <ArgList>hostName = Logon.reptDevName,hostIpAddr = Logon.reptDevIpAddr,count = Logon.COUNT(*),avgMatchedEvents = Logon.STAT_AVG(COUNT(*):115)</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

