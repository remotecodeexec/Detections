<?xml version="1.0" encoding="UTF-8"?><rules><DataRequest functionCategory="Security" mode="Streaming" tactic="Exfiltration" technique="T1048.001" techniqueName="Exfiltration Over Alternative Protocol: Exfiltration Over Symmetric Encrypted Non-C2 Protocol"><Name>Symantec AV detected a malicious site communication / SCW</Name><Description>This rule tracks alerts from the symantec AV pertaining to malicous domain traffic detections</Description><Remediation/><DataSource>Symantec via SYSLOG</DataSource><DetectionTechnology>Correlation</DetectionTechnology><PatternClause window="300">
<SubPattern id="1533851859" name="Malicious_domain">
<SingleEvtConstr>eventType="Symantec-AV-Malicious-Site"</SingleEvtConstr>
<GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
<GroupByAttr>srcName,srcUser,procName,infoURL</GroupByAttr>
</SubPattern>
</PatternClause><IncidentDef eventType="Symantec_AV_detected_a_malicious_site_communication_SCW" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="3600" severity="9">
<ArgList>srcName = Malicious_domain.srcName,srcUser = Malicious_domain.srcUser,procName = Malicious_domain.procName,infoURL = Malicious_domain.infoURL</ArgList>
</IncidentDef><DynWatchLists/><TriggerEventDisplay>
<AttrList>phRecvTime,eventType,reptDevIpAddr,rawEventMsg</AttrList>
</TriggerEventDisplay><IncidentTitle>A malicious domain was contacted from $srcName </IncidentTitle></DataRequest></rules>
