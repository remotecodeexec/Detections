<rules>
    <DataRequest functionCategory="Security" mode="Streaming" tactic="Discovery" technique="T1082" techniqueName="System Information Discovery">
        <Name>Enumeration of System Information / SCW</Name>
        <Description>Detects system information enumeration and discovery via built-in tools.</Description>
        <TriggerEventDisplay>
            <AttrList>phRecvTime,eventType,hostName,procName,swParam,rawEventMsg</AttrList>
        </TriggerEventDisplay>
        <IncidentTitle>Enumeration of System Information on $hostName</IncidentTitle>
        <Remediation/>
        <DataSource>Linux Process Monitoring via FortiSIEM Agent</DataSource>
        <DetectionTechnology>Correlation</DetectionTechnology>
        <PatternClause window="300">
            <SubPattern id="5688110009" name="Filter">
                <SingleEvtConstr>eventType="LINUX_PROCESS_EXEC" AND (procName="uname" OR (procName IN ("cat","less","more") AND swParam REGEXP ".* /etc/issue.*|.* /etc/profile.*|.* /etc/services.*|.* /proc/cpuinfo.*|.* /proc/version.*"))</SingleEvtConstr>
                <GroupEvtConstr>COUNT(*)&gt;=1</GroupEvtConstr>
                <GroupByAttr>hostName,procName,command,swParam</GroupByAttr>
            </SubPattern>
        </PatternClause>
        <Tag>Host Discovery</Tag>
        <IncidentDef eventType="Enumeration_of_System_Information_SCW" eventTypeGroup="PH_SYS_EVENT_PH_RULE_SEC" fireFreq="86400" severity="5">
            <ArgList>hostName = Filter.hostName,procName = Filter.procName,swParam = Filter.swParam</ArgList>
        </IncidentDef>
        <DynWatchLists/>
    </DataRequest>
</rules>

